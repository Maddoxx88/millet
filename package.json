{
  "name": "@sshirke/millet",
  "version": "0.2.0",
  "description": "Semantic HTML, styled. Zero classes required.",
  "type": "module",
  "author": "Sunit Shirke",
  "license": "MIT",
  "homepage": "https://maddoxx88.github.io/millet",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maddoxx88/millet.git"
  },
  "exports": {
    ".": {
      "import": "./src/js/core.js"
    },
    "./enhance": {
      "import": "./src/js/enhance.js"
    },
    "./css": "./src/css/millet.css",
    "./dist/css": "./dist/millet.min.css",
    "./dist/js": "./dist/millet.min.js"
  },
  "files": [
    "src/",
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs",
    "measure": "node measure.mjs",
    "prepublishOnly": "npm run build"
  },
  "main": "./dist/millet.min.js",
  "style": "./dist/millet.min.css",
  "unpkg": "./dist/millet.min.js",
  "jsdelivr": "./dist/millet.min.js",
  "keywords": [
    "css",
    "ui",
    "classless",
    "semantic",
    "lightweight",
    "zero-dependency",
    "dark-mode",
    "accessible"
  ],
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
